# Copy this file to .env.local and paste your real key. Never commit .env.local.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# Optional: override the model (defaults to claude-haiku-4-5)
ANTHROPIC_MODEL=claude-haiku-4-5

# Dev-only: set to 1 to bypass the real Anthropic call in /api/generate-theme
# and /api/generate-insights, using a canned local response instead (picks a
# layout from keywords in your prompt, binds cells to your uploaded data if
# any; Summary page gets labeled mock captions). Lets you exercise AI Assist
# and the Summary page end-to-end with no API key / no credit needed. Leave
# unset/0 for real AI generation.
# AI_MOCK_MODE=1
